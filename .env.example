# comforceEva — environment template. Copy to `.env` and fill in.
# `.env` is gitignored; NEVER commit real values.

# ── Platform API (platform/apps/api) ─────────────────────────
PORT=8080
HOST=0.0.0.0
# Where study configs live. In Azure, mount Azure Files here (PHI off-image).
STUDIES_DIR=/data/studies
# Anthropic Haiku key for the live per-turn extractor (optional; falls back to rule-based if unset)
ANTHROPIC_API_KEY=

# ── Live-platform scraper (studygen.mjs crawl/scrape — optional, dev only) ──
DM_LOGIN_URL=https://dmclinicalresearch.app.alleviatehealth.care/login
DM_STUDY_URL=
DM_USER=
DM_PASS=
